def send_notifications_view(request, pk):
    application = get_object_or_404(LoanApplication, pk=pk)
    sender_name = request.POST.get("sender_name", "").strip() or None
    try:
        results = send_record_notifications(application, sender_name=sender_name)
    except NotificationError as exc:
        messages.error(request, str(exc))
    else:
        status_text = ", ".join(f"{channel}: {message}" for channel, message in results.items())
        messages.success(request, f"Notification result - {status_text}")
    return redirect("notifications:detail", pk=pk)


