from django.views.decorators.http import require_POST
from django.views.decorators.csrf import csrf_protect
import json
from .services import build_message, send_email_notification, send_whatsapp_notification

@require_POST
@csrf_protect
def bulk_send_notifications(request):
    """Send bulk notifications to ALL records based on current filters"""
    try:
        data = json.loads(request.POST.get('filter_data', '{}'))
        notification_type = data.get('type', 'email')
        sender_name = data.get('sender_name', '').strip() or None
        
        # Get filter parameters from request
        search = data.get('search', '').strip()
        status = data.get('status', '').strip()
        filter_type = data.get('filter_type', '').strip()
        month_year = data.get('month_year', '').strip()
        year_filter = data.get('year', '').strip()
        start_date = data.get('start_date', '').strip()
        end_date = data.get('end_date', '').strip()
        
        # Build queryset based on filters (same as DashboardListView)
        queryset = LoanApplication.objects.all()
        
        # Search filter
        if search:
            queryset = queryset.filter(
                Q(customer_name__icontains=search) |
                Q(invoice_no__icontains=search) |
                Q(item_name__icontains=search) |
                Q(employee_name__icontains=search)
            )
        
        # Status filter
        if status:
            status = status.lower()
            if status == 'overdue':
                queryset = queryset.filter(
                    ~Q(payment_status__iexact='paid') & ~Q(payment_status__icontains='done'),
                    invoice_due_date__lt=timezone.localdate()
                )
            else:
                if status == 'paid':
                    queryset = queryset.filter(
                        Q(payment_status__iexact='paid') | Q(payment_status__icontains='done')
                    )
                else:
                    queryset = queryset.filter(payment_status__iexact=status)
        
        # Monthly filter
        if filter_type == "monthly" and month_year:
            try:
                year, month = month_year.split("-")
                queryset = queryset.filter(
                    invoice_due_date__year=int(year),
                    invoice_due_date__month=int(month)
                )
            except (ValueError, IndexError):
                pass
        
        # Yearly filter
        elif filter_type == "yearly" and year_filter:
            try:
                queryset = queryset.filter(invoice_due_date__year=int(year_filter))
            except ValueError:
                pass
        
        # Date range filter
        elif filter_type == "date_range" and start_date and end_date:
            try:
                start = datetime.strptime(start_date, '%Y-%m-%d').date()
                end = datetime.strptime(end_date, '%Y-%m-%d').date()
                queryset = queryset.filter(invoice_due_date__range=[start, end])
            except (ValueError, TypeError):
                pass
        
        total_records = queryset.count()
        
        if total_records == 0:
            messages.error(request, "No records found with current filter")
            return redirect('notifications:dashboard')
        
        success_count = 0
        fail_count = 0
        errors = []
        
        for application in queryset:
            try:
                message = build_message(application, sender_name=sender_name)
                if notification_type == 'email':
                    send_email_notification(application, message, sender_name=sender_name)
                elif notification_type == 'whatsapp':
                    send_whatsapp_notification(application, message, sender_name=sender_name)
                success_count += 1
            except Exception as e:
                fail_count += 1
                errors.append(f"{application.name}: {str(e)}")
        
        # Build filter description for message
        filter_desc = ""
        if status:
            filter_desc = f" (Filter: {status.upper()})"
        elif filter_type == "monthly" and month_year:
            filter_desc = f" (Filter: Monthly - {month_year})"
        elif filter_type == "yearly" and year_filter:
            filter_desc = f" (Filter: Yearly - {year_filter})"
        elif filter_type == "date_range" and start_date and end_date:
            filter_desc = f" (Filter: Date Range - {start_date} to {end_date})"
        
        if success_count > 0:
            messages.success(
                request, 
                f"✅ {success_count} records{filter_desc} ko {notification_type} The notification has been successfully sent "
                f"❌ {fail_count} fail."
            )
        else:
            messages.error(request, f"No notifications could be sent. Errors: {', '.join(errors[:3])}")
            
    except Exception as e:
        messages.error(request, f"Error: {str(e)}")
    
    return redirect('notifications:dashboard')






