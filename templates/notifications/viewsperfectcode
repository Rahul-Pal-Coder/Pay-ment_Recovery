# Update the DashboardListView get_context_data method
class DashboardListView(ListView):
    model = LoanApplication
    template_name = "notifications/dashboard.html"
    context_object_name = "applications"

    def get_queryset(self):
        queryset = super().get_queryset()
        search = self.request.GET.get("search", "").strip()
        status = self.request.GET.get("status", "").strip().lower()
        filter_type = self.request.GET.get("filter_type", "").strip()
        month_year = self.request.GET.get("month_year", "").strip()
        year_filter = self.request.GET.get("year", "").strip()
        start_date = self.request.GET.get("start_date", "").strip()
        end_date = self.request.GET.get("end_date", "").strip()

        if search:
            queryset = queryset.filter(
                Q(customer_name__icontains=search) |
                Q(invoice_no__icontains=search) |
                Q(item_name__icontains=search) |
                Q(employee_name__icontains=search)
            )
        
        if status:
            if status == 'overdue':
                queryset = queryset.filter(
                    ~Q(payment_status__iexact='paid'),
                    invoice_due_date__lt=timezone.localdate()
                )
            else:
                queryset = queryset.filter(payment_status__iexact=status)

        if filter_type == "monthly" and month_year:
            try:
                year, month = month_year.split("-")
                queryset = queryset.filter(
                    invoice_due_date__year=int(year),
                    invoice_due_date__month=int(month)
                )
            except (ValueError, IndexError):
                pass
        elif filter_type == "yearly" and year_filter:
            try:
                queryset = queryset.filter(invoice_due_date__year=int(year_filter))
            except ValueError:
                pass
        elif filter_type == "date_range" and start_date and end_date:
            try:
                start = datetime.strptime(start_date, '%Y-%m-%d').date()
                end = datetime.strptime(end_date, '%Y-%m-%d').date()
                queryset = queryset.filter(invoice_due_date__range=[start, end])
            except (ValueError, TypeError):
                pass

        return queryset

    def get_context_data(self, **kwargs):
        context = super().get_context_data(**kwargs)
        
        # Calculate statistics based on current filtered records
        stats = self.get_queryset().aggregate(
            total_records=Count("id"),
            total_invoice_amount=Sum("invoice_amount"),
            total_received=Sum("received_amount"),
            total_balance=Sum("balance_amount"),
        )
        
        context["stats"] = stats
        context["today"] = timezone.localdate()
        context["selected_status"] = self.request.GET.get("status", "")
        context["search_query"] = self.request.GET.get("search", "")
        context["filter_type"] = self.request.GET.get("filter_type", "")
        context["month_year"] = self.request.GET.get("month_year", "")
        context["year_filter"] = self.request.GET.get("year", "")
        context["start_date"] = self.request.GET.get("start_date", "")
        context["end_date"] = self.request.GET.get("end_date", "")
        
        return context



class LoanApplicationCreateView(FormView):
    form_class = ExcelUploadForm
    template_name = "notifications/form.html"
    success_url = reverse_lazy('notifications:dashboard')

    def form_valid(self, form):
        excel_file = form.cleaned_data["excel_file"]
        try:
            result = import_loan_applications_from_excel(excel_file)
        except ExcelImportError as exc:
            messages.error(self.request, str(exc))
            return redirect(self.success_url)

        if result["created_count"] or result["updated_count"]:
            skip_msg = ""
            if result.get("skipped_count", 0) > 0:
                skip_msg = f" (⚠️ {result['skipped_count']} records skip hua - check errors below)"
            messages.success(
                self.request,
                f"Excel sync complete. {result['created_count']} new records create hue aur {result['updated_count']} records update hue.{skip_msg}",
            )
        if result["errors"]:
            error_msg = "\n".join(result["errors"][:10])  # Show first 10 errors
            if len(result["errors"]) > 10:
                error_msg += f"\n... aur {len(result['errors']) - 10} aur errors"
            messages.warning(
                self.request,
                f"⚠️ {result.get('skipped_count', 0)} rows import nahi hui: {'; '.join(result['errors'][:5])}",
            )
        return redirect(self.success_url)

    def form_invalid(self, form):
        if "excel_file" in form.errors:
            messages.error(self.request, form.errors["excel_file"][0])
        else:
            messages.error(self.request, "Koi Excel file upload nahi ki gayi.")
        return redirect(self.success_url)


